<?xml version="1.0" encoding="utf-8"?>
<!--
    OptimaAI Security
    ================
    Security groups, rules, and record rules.
-->
<odoo>
    <!-- ==========================================
         User Groups
         ========================================== -->
    
    <!-- Base User Group -->
    <record id="group_optimaai_user" model="res.groups">
        <field name="name">OptimaAI User</field>
        <field name="comment">Basic access to OptimaAI features</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Analyst Group -->
    <record id="group_optimaai_analyst" model="res.groups">
        <field name="name">OptimaAI Analyst</field>
        <field name="comment">Can create datasets, predictions, and insights</field>
        <field name="implied_ids" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <!-- Manager Group -->
    <record id="group_optimaai_admin" model="res.groups">
        <field name="name">OptimaAI Administrator</field>
        <field name="comment">Full access to all OptimaAI features</field>
        <field name="implied_ids" eval="[(4, ref('group_optimaai_analyst'))]"/>
    </record>
    
    <!-- Give Admin users the OptimaAI Administrator group by default -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('optimaai.group_optimaai_admin'))]"/>
    </record>
    <record id="base.user_root" model="res.users">
        <field name="groups_id" eval="[(4, ref('optimaai.group_optimaai_admin'))]"/>
    </record>
    
    <!-- ==========================================
         Record Rules
         ==========================================
         
         Note: Most models do not have company_id,
         so we use simple group-based access rules
         instead of multi-company domain filters.
    -->
    
    <!-- Canvas: Owner or public canvases -->
    <record id="rule_canvas_user" model="ir.rule">
        <field name="name">OptimaAI Canvas: User Access</field>
        <field name="model_id" ref="model_optimaai_canvas"/>
        <field name="domain_force">['|', ('created_by', '=', user.id), ('created_by', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <!-- Canvas: Company rule (canvas has company_id) -->
    <record id="rule_canvas_company" model="ir.rule">
        <field name="name">OptimaAI Canvas: Company</field>
        <field name="model_id" ref="model_optimaai_canvas"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Canvas Block: Follow canvas access -->
    <record id="rule_canvas_block_user" model="ir.rule">
        <field name="name">OptimaAI Canvas Block: User Access</field>
        <field name="model_id" ref="model_optimaai_canvas_block"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <!-- Canvas Connection: Company rule (has related company_id) -->
    <record id="rule_canvas_connection_company" model="ir.rule">
        <field name="name">OptimaAI Canvas Connection: Company</field>
        <field name="model_id" ref="model_optimaai_canvas_connection"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- ==========================================
         Owner Rules (Users see their own records)
         ========================================== -->
    
    <!-- API Key: User can only see their own keys -->
    <record id="rule_api_key_user" model="ir.rule">
        <field name="name">OptimaAI API Key: Own Keys</field>
        <field name="model_id" ref="model_res_users_api_key"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- API Key: Admin sees all -->
    <record id="rule_api_key_admin" model="ir.rule">
        <field name="name">OptimaAI API Key: Admin</field>
        <field name="model_id" ref="model_res_users_api_key"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_admin'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- ==========================================
         Integration Access Rules
         ========================================== -->
    
    <!-- Integration: Only admins can manage integrations -->
    <record id="rule_integration_admin" model="ir.rule">
        <field name="name">OptimaAI Integration: Admin Management</field>
        <field name="model_id" ref="model_optimaai_integration_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_admin'))]"/>
    </record>
</odoo>