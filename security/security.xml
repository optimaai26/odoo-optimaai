<?xml version="1.0" encoding="utf-8"?>
<!--
    OptimaAI Security
    ================
    Security groups, rules, and record rules.
-->
<odoo>
    <!-- ==========================================
         User Groups
         ========================================== -->
    
    <!-- Base User Group -->
    <record id="group_optimaai_user" model="res.groups">
        <field name="name">OptimaAI User</field>
        <field name="category_id" ref="base.module_category_tools"/>
        <field name="comment">Basic access to OptimaAI features</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Analyst Group -->
    <record id="group_optimaai_analyst" model="res.groups">
        <field name="name">OptimaAI Analyst</field>
        <field name="category_id" ref="base.module_category_tools"/>
        <field name="comment">Can create datasets, predictions, and insights</field>
        <field name="implied_ids" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <!-- Manager Group -->
    <record id="group_optimaai_admin" model="res.groups">
        <field name="name">OptimaAI Administrator</field>
        <field name="category_id" ref="base.module_category_tools"/>
        <field name="comment">Full access to all OptimaAI features</field>
        <field name="implied_ids" eval="[(4, ref('group_optimaai_analyst'))]"/>
    </record>
    
    <!-- ==========================================
         Multi-Company Rules
         ========================================== -->
    
    <!-- Dataset Company Rule -->
    <record id="rule_dataset_company" model="ir.rule">
        <field name="name">OptimaAI Dataset: Company</field>
        <field name="model_id" ref="model_optimaai_dataset"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Prediction Company Rule -->
    <record id="rule_prediction_company" model="ir.rule">
        <field name="name">OptimaAI Prediction: Company</field>
        <field name="model_id" ref="model_optimaai_prediction"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Insight Company Rule -->
    <record id="rule_insight_company" model="ir.rule">
        <field name="name">OptimaAI Insight: Company</field>
        <field name="model_id" ref="model_optimaai_insight"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Report Company Rule -->
    <record id="rule_report_company" model="ir.rule">
        <field name="name">OptimaAI Report: Company</field>
        <field name="model_id" ref="model_optimaai_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Canvas Company Rule -->
    <record id="rule_canvas_company" model="ir.rule">
        <field name="name">OptimaAI Canvas: Company</field>
        <field name="model_id" ref="model_optimaai_canvas"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- KPI Company Rule -->
    <record id="rule_kpi_company" model="ir.rule">
        <field name="name">OptimaAI KPI: Company</field>
        <field name="model_id" ref="model_optimaai_kpi"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Integration Config Company Rule -->
    <record id="rule_integration_company" model="ir.rule">
        <field name="name">OptimaAI Integration: Company</field>
        <field name="model_id" ref="model_optimaai_integration_config"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- Access Request Company Rule -->
    <record id="rule_access_request_company" model="ir.rule">
        <field name="name">OptimaAI Access Request: Company</field>
        <field name="model_id" ref="model_optimaai_access_request"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
    <!-- ==========================================
         Owner Rules (Users see their own records)
         ========================================== -->
    
    <!-- API Key: User can only see their own keys -->
    <record id="rule_api_key_user" model="ir.rule">
        <field name="name">OptimaAI API Key: Own Keys</field>
        <field name="model_id" ref="model_res_users_api_key"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- API Key: Admin sees all -->
    <record id="rule_api_key_admin" model="ir.rule">
        <field name="name">OptimaAI API Key: Admin</field>
        <field name="model_id" ref="model_res_users_api_key"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_admin'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- Access Request: User sees own requests -->
    <record id="rule_access_request_user" model="ir.rule">
        <field name="name">OptimaAI Access Request: Own Requests</field>
        <field name="model_id" ref="model_optimaai_access_request"/>
        <field name="domain_force">['|', ('requester_id', '=', user.id), ('approver_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <!-- ==========================================
         Canvas Access Rules
         ========================================== -->
    
    <!-- Canvas: Owner or team member -->
    <record id="rule_canvas_user" model="ir.rule">
        <field name="name">OptimaAI Canvas: User Access</field>
        <field name="model_id" ref="model_optimaai_canvas"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('access_level', '!=', 'private')]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <!-- Canvas Block: Follow canvas access -->
    <record id="rule_canvas_block_user" model="ir.rule">
        <field name="name">OptimaAI Canvas Block: User Access</field>
        <field name="model_id" ref="model_optimaai_canvas_block"/>
        <field name="domain_force">[('canvas_id.access_level', '!=', 'private')]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <!-- ==========================================
         Integration Access Rules
         ========================================== -->
    
    <!-- Integration: Only admins can manage integrations -->
    <record id="rule_integration_admin" model="ir.rule">
        <field name="name">OptimaAI Integration: Admin Management</field>
        <field name="model_id" ref="model_optimaai_integration_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_optimaai_admin'))]"/>
    </record>
    
    <!-- ==========================================
         Menu Access
         ========================================== -->
    
    <!-- Assign menu to groups -->
    <record id="menu_optimaai" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <record id="menu_optimaai_dashboard" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <record id="menu_optimaai_datasets" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_analyst'))]"/>
    </record>
    
    <record id="menu_optimaai_predictions" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_analyst'))]"/>
    </record>
    
    <record id="menu_optimaai_insights" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_user'))]"/>
    </record>
    
    <record id="menu_optimaai_reports" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_analyst'))]"/>
    </record>
    
    <record id="menu_optimaai_canvases" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_analyst'))]"/>
    </record>
    
    <record id="menu_optimaai_integrations" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_admin'))]"/>
    </record>
    
    <record id="menu_optimaai_settings" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('group_optimaai_admin'))]"/>
    </record>
</odoo>