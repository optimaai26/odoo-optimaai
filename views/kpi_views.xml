<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         KPI Views
         ========================================== -->
    
    <!-- KPI Tree View -->
    <record id="view_kpi_tree" model="ir.ui.view">
        <field name="name">optimaai.kpi.tree</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <list string="KPIs" decoration-success="status=='exceeded'" 
                  decoration-warning="status=='warning'"
                  decoration-danger="status=='critical'">
                <field name="name"/>
                <field name="category"/>
                <field name="current_value"/>
                <field name="target_value"/>
                <field name="unit"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="status" widget="badge"/>
                <field name="trend"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    
    <!-- KPI Form View -->
    <record id="view_kpi_form" model="ir.ui.view">
        <field name="name">optimaai.kpi.form</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <form string="KPI">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="KPI Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="unit"/>
                            <field name="owner_id"/>
                            <field name="show_on_dashboard"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <group string="Values">
                        <group>
                            <field name="current_value"/>
                            <field name="previous_value"/>
                            <field name="baseline_value"/>
                        </group>
                        <group>
                            <field name="target_value"/>
                            <field name="warning_threshold"/>
                            <field name="critical_threshold"/>
                        </group>
                    </group>
                    
                    <group string="Progress">
                        <group>
                            <field name="progress_percentage"/>
                            <field name="trend"/>
                        </group>
                        <group>
                            <field name="status"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Data Source Tab -->
                        <page string="Data Source" name="data_source">
                            <group>
                                <field name="data_source_type"/>
                                <field name="computation_formula" 
                                       invisible="data_source_type != 'computed'"/>
                                <field name="dataset_id" 
                                       invisible="data_source_type != 'dataset'"/>
                            </group>
                        </page>
                        
                        <!-- Schedule Tab -->
                        <page string="Schedule" name="schedule">
                            <group>
                                <field name="measurement_frequency"/>
                                <field name="last_measurement_date"/>
                                <field name="next_measurement_date"/>
                            </group>
                        </page>
                        
                        <!-- Display Tab -->
                        <page string="Display" name="display">
                            <group>
                                <field name="color"/>
                                <field name="icon"/>
                                <field name="sequence"/>
                            </group>
                        </page>
                        
                        <!-- History Tab -->
                        <page string="History" name="history">
                            <field name="history_ids">
                                <list>
                                    <field name="measurement_date"/>
                                    <field name="value"/>
                                    <field name="previous_value"/>
                                    <field name="measured_by"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- KPI Search View -->
    <record id="view_kpi_search" model="ir.ui.view">
        <field name="name">optimaai.kpi.search</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <search string="Search KPIs">
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <filter name="on_track" string="On Track" domain="[('status', '=', 'on_track')]"/>
                <filter name="warning" string="Warning" domain="[('status', '=', 'warning')]"/>
                <filter name="critical" string="Critical" domain="[('status', '=', 'critical')]"/>
                <filter name="exceeded" string="Exceeded" domain="[('status', '=', 'exceeded')]"/>
                <separator/>
                <filter name="improving" string="Improving" domain="[('trend', '=', 'up')]"/>
                <filter name="declining" string="Declining" domain="[('trend', '=', 'down')]"/>
                <filter name="dashboard" string="On Dashboard" domain="[('show_on_dashboard', '=', True)]"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Trend" name="group_trend" context="{'group_by': 'trend'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- KPI Kanban View -->
    <record id="view_kpi_kanban" model="ir.ui.view">
        <field name="name">optimaai.kpi.kanban</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="current_value"/>
                <field name="target_value"/>
                <field name="unit"/>
                <field name="status"/>
                <field name="trend"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                                <div class="row">
                                    <div class="col-xs-6">
                                        <span class="text-muted">Current:</span>
                                        <strong><field name="current_value"/> <field name="unit"/></strong>
                                    </div>
                                    <div class="col-xs-6">
                                        <span class="text-muted">Target:</span>
                                        <field name="target_value"/> <field name="unit"/>
                                    </div>
                                </div>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <span t-if="record.trend.value == 'up'" class="text-success">
                                    <i class="fa fa-arrow-up"/> Up
                                </span>
                                <span t-if="record.trend.value == 'down'" class="text-danger">
                                    <i class="fa fa-arrow-down"/> Down
                                </span>
                                <span t-if="record.trend.value == 'stable'" class="text-muted">
                                    <i class="fa fa-minus"/> Stable
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- KPI Action -->
    <record id="action_kpi" model="ir.actions.act_window">
        <field name="name">KPIs</field>
        <field name="res_model">optimaai.kpi</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_kpi_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No KPIs found
            </p>
            <p>
                Define KPIs to track and monitor your business performance.
            </p>
        </field>
    </record>
    
    <!-- Insight Action by KPI -->
    <record id="action_insight_by_kpi" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">list,form</field>
    </record>
    
</odoo>