<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         KPI Views
         ========================================== -->
    
    <!-- KPI Tree View -->
    <record id="view_kpi_tree" model="ir.ui.view">
        <field name="name">optimaai.kpi.tree</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <list string="KPIs" 
                  decoration-success="status=='exceeded'" 
                  decoration-warning="status=='warning'"
                  decoration-danger="status=='critical'"
                  multi_edit="1"
                  sample="1">
                <field name="name" string="KPI"/>
                <field name="category" widget="badge"/>
                <field name="current_value" string="Current"/>
                <field name="target_value" string="Target"/>
                <field name="unit"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('on_track', 'exceeded')"
                       decoration-warning="status=='warning'"
                       decoration-danger="status=='critical'"/>
                <field name="trend" widget="badge"
                       decoration-success="trend=='up'"
                       decoration-danger="trend=='down'"
                       decoration-info="trend=='stable'"/>
                <field name="owner_id" widget="many2one_avatar_user" optional="show"/>
                <field name="measurement_frequency" optional="hide"/>
                <field name="last_measurement_date" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>
    
    <!-- KPI Form View -->
    <record id="view_kpi_form" model="ir.ui.view">
        <field name="name">optimaai.kpi.form</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <form string="KPI">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <!-- Critical alert -->
                    <div class="alert alert-danger mb-3" role="alert"
                         invisible="status != 'critical'">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Critical:</strong> This KPI is below the critical threshold. Immediate action required.
                    </div>
                    <!-- Warning alert -->
                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="status != 'warning'">
                        <i class="fa fa-warning me-2"/>
                        <strong>Warning:</strong> This KPI is approaching the warning threshold.
                    </div>
                    <!-- Exceeded alert -->
                    <div class="alert alert-success mb-3" role="alert"
                         invisible="status != 'exceeded'">
                        <i class="fa fa-trophy me-2"/>
                        <strong>Exceeded!</strong> This KPI has surpassed its target. Great job!
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Monthly Revenue Growth"/></h1>
                        <field name="code" placeholder="e.g. REV_GROWTH"/>
                    </div>
                    
                    <group>
                        <group string="Definition">
                            <field name="category" widget="radio"/>
                            <field name="description" placeholder="What does this KPI measure?"/>
                            <field name="unit"/>
                            <field name="owner_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Current Performance">
                            <field name="current_value"/>
                            <field name="target_value"/>
                            <field name="progress_percentage" widget="progressbar"/>
                            <field name="trend" widget="badge"
                                   decoration-success="trend=='up'"
                                   decoration-danger="trend=='down'"
                                   decoration-info="trend=='stable'"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Thresholds">
                            <field name="warning_threshold"/>
                            <field name="critical_threshold"/>
                            <field name="baseline_value"/>
                            <field name="previous_value"/>
                        </group>
                        <group string="Settings">
                            <field name="show_on_dashboard" widget="boolean_toggle"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Data Source Tab -->
                        <page string="Data Source" name="data_source">
                            <group>
                                <field name="data_source_type" widget="radio"/>
                                <field name="computation_formula" 
                                       invisible="data_source_type != 'computed'"
                                       placeholder="Enter computation formula..."/>
                                <field name="dataset_id" 
                                       invisible="data_source_type != 'dataset'"/>
                            </group>
                        </page>
                        
                        <!-- Schedule Tab -->
                        <page string="Schedule" name="schedule">
                            <group>
                                <group>
                                    <field name="measurement_frequency" widget="radio"/>
                                </group>
                                <group>
                                    <field name="last_measurement_date"/>
                                    <field name="next_measurement_date"/>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Display Tab -->
                        <page string="Display" name="display">
                            <group>
                                <group>
                                    <field name="color" widget="color"/>
                                    <field name="icon"/>
                                </group>
                                <group>
                                    <field name="sequence"/>
                                </group>
                            </group>
                        </page>
                        
                        <!-- History Tab -->
                        <page string="History" name="history">
                            <field name="history_ids">
                                <list>
                                    <field name="measurement_date"/>
                                    <field name="value"/>
                                    <field name="previous_value"/>
                                    <field name="measured_by" widget="many2one_avatar_user"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- KPI Search View -->
    <record id="view_kpi_search" model="ir.ui.view">
        <field name="name">optimaai.kpi.search</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <search string="Search KPIs">
                <field name="name" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="category"/>
                <field name="owner_id"/>
                <separator/>
                <filter name="on_track" string="On Track" domain="[('status', '=', 'on_track')]"/>
                <filter name="warning" string="Warning" domain="[('status', '=', 'warning')]"/>
                <filter name="critical" string="Critical" domain="[('status', '=', 'critical')]"/>
                <filter name="exceeded" string="Exceeded" domain="[('status', '=', 'exceeded')]"/>
                <separator/>
                <filter name="improving" string="⬆ Improving" domain="[('trend', '=', 'up')]"/>
                <filter name="declining" string="⬇ Declining" domain="[('trend', '=', 'down')]"/>
                <filter name="dashboard" string="On Dashboard" domain="[('show_on_dashboard', '=', True)]"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Trend" name="group_trend" context="{'group_by': 'trend'}"/>
                    <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- KPI Kanban View -->
    <record id="view_kpi_kanban" model="ir.ui.view">
        <field name="name">optimaai.kpi.kanban</field>
        <field name="model">optimaai.kpi</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="current_value"/>
                <field name="target_value"/>
                <field name="unit"/>
                <field name="status"/>
                <field name="trend"/>
                <field name="progress_percentage"/>
                <field name="owner_id"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <field name="name" class="fw-bold fs-5"/>
                                <div class="text-muted small"><field name="code"/></div>
                            </div>
                            <field name="status" widget="label"
                                   decoration-success="status in ('on_track', 'exceeded')"
                                   decoration-warning="status=='warning'"
                                   decoration-danger="status=='critical'"/>
                        </div>
                        <hr class="my-2"/>
                        <div class="row g-1 text-center">
                            <div class="col-6">
                                <div class="fw-bold fs-4 text-primary">
                                    <field name="current_value"/>
                                </div>
                                <small class="text-muted">Current (<field name="unit"/>)</small>
                            </div>
                            <div class="col-6">
                                <div class="fw-bold fs-4">
                                    <field name="target_value"/>
                                </div>
                                <small class="text-muted">Target (<field name="unit"/>)</small>
                            </div>
                        </div>
                        <div class="mt-2">
                            <field name="progress_percentage" widget="progressbar"/>
                        </div>
                        <hr class="my-2"/>
                        <div class="d-flex justify-content-between align-items-center">
                            <field name="owner_id" widget="many2one_avatar_user"/>
                            <field name="trend" widget="badge"
                                   decoration-success="trend=='up'"
                                   decoration-danger="trend=='down'"
                                   decoration-info="trend=='stable'"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- KPI Action -->
    <record id="action_kpi" model="ir.actions.act_window">
        <field name="name">KPIs</field>
        <field name="res_model">optimaai.kpi</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_kpi_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first KPI
            </p>
            <p>
                Track and monitor your business performance with key performance indicators.
            </p>
        </field>
    </record>
    
    <!-- Insight Action by KPI -->
    <record id="action_insight_by_kpi" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">list,form</field>
    </record>
    
</odoo>