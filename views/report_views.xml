<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Report Views
         ========================================== -->
    
    <!-- Report Tree View -->
    <record id="view_report_tree" model="ir.ui.view">
        <field name="name">optimaai.report.tree</field>
        <field name="model">optimaai.report</field>
        <field name="arch" type="xml">
            <tree string="Reports" decoration-warning="status=='draft'" 
                  decoration-success="status=='published'">
                <field name="name"/>
                <field name="report_type"/>
                <field name="status" widget="badge"/>
                <field name="schedule_type"/>
                <field name="next_run_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>
    
    <!-- Report Form View -->
    <record id="view_report_form" model="ir.ui.view">
        <field name="name">optimaai.report.form</field>
        <field name="model">optimaai.report</field>
        <field name="arch" type="xml">
            <form string="Report">
                <header>
                    <button name="action_generate" type="object" string="Generate Now" 
                            class="btn-primary"/>
                    <button name="action_publish" type="object" string="Publish" 
                            attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_unpublish" type="object" string="Unpublish" 
                            attrs="{'invisible': [('status', '!=', 'published')]}"/>
                    <button name="action_duplicate" type="object" string="Duplicate"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Report Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="schedule_type"/>
                            <field name="next_run_date" attrs="{'invisible': [('schedule_type', '=', 'manual')]}"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="last_run_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Content Tab -->
                        <page string="Content" name="content">
                            <group>
                                <field name="description"/>
                            </group>
                            <group string="Report Content">
                                <field name="content" nolabel="1" widget="html"/>
                            </group>
                        </page>
                        
                        <!-- Data Sources Tab -->
                        <page string="Data Sources" name="data_sources">
                            <group>
                                <field name="dataset_ids" widget="many2many_tags"/>
                                <field name="prediction_ids" widget="many2many_tags"/>
                                <field name="insight_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        
                        <!-- Filters Tab -->
                        <page string="Filters" name="filters">
                            <group>
                                <field name="filter_config" widget="text"/>
                            </group>
                        </page>
                        
                        <!-- Layout Tab -->
                        <page string="Layout" name="layout">
                            <group>
                                <field name="layout_config" widget="text"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Report Search View -->
    <record id="view_report_search" model="ir.ui.view">
        <field name="name">optimaai.report.search</field>
        <field name="model">optimaai.report</field>
        <field name="arch" type="xml">
            <search string="Search Reports">
                <field name="name"/>
                <filter name="draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                <filter name="published" string="Published" domain="[('status', '=', 'published')]"/>
                <filter name="archived" string="Archived" domain="[('status', '=', 'archived')]"/>
                <separator/>
                <filter name="scheduled" string="Scheduled" domain="[('schedule_type', '!=', 'manual')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'report_type'}"/>
                    <filter string="Schedule" name="group_schedule" context="{'group_by': 'schedule_type'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Report Action -->
    <record id="action_report" model="ir.actions.act_window">
        <field name="name">Reports</field>
        <field name="res_model">optimaai.report</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reports found
            </p>
            <p>
                Create custom reports to visualize your data insights.
            </p>
        </field>
    </record>
    
</odoo>