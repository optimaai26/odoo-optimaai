<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Report Views
         ========================================== -->
    
    <!-- Report Tree View -->
    <record id="view_report_tree" model="ir.ui.view">
        <field name="name">optimaai.report.tree</field>
        <field name="model">optimaai.report</field>
        <field name="arch" type="xml">
            <list string="Reports" decoration-warning="status=='draft'" 
                  decoration-success="status=='completed'"
                  decoration-danger="status=='failed'">
                <field name="name"/>
                <field name="report_type"/>
                <field name="format"/>
                <field name="status" widget="badge"/>
                <field name="schedule_type"/>
                <field name="next_run_date"/>
                <field name="last_run_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    
    <!-- Report Form View -->
    <record id="view_report_form" model="ir.ui.view">
        <field name="name">optimaai.report.form</field>
        <field name="model">optimaai.report</field>
        <field name="arch" type="xml">
            <form string="Report">
                <header>
                    <button name="action_generate" type="object" string="Generate Now" 
                            class="btn-primary"/>
                    <button name="action_download" type="object" string="Download" 
                            invisible="status != 'completed'"/>
                    <button name="action_preview" type="object" string="Preview" 
                            invisible="status != 'completed'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,pending,generating,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Report Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="format"/>
                            <field name="schedule_type"/>
                            <field name="schedule_time" invisible="schedule_type == 'manual'"/>
                            <field name="schedule_day" invisible="schedule_type in ('manual', 'daily')"/>
                            <field name="next_run_date" invisible="schedule_type == 'manual'"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="last_run_date"/>
                            <field name="created_by"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Data Sources Tab -->
                        <page string="Data Sources" name="data_sources">
                            <group>
                                <field name="dataset_ids" widget="many2many_tags"/>
                                <field name="prediction_ids" widget="many2many_tags"/>
                                <field name="insight_ids" widget="many2many_tags"/>
                                <field name="kpi_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        
                        <!-- Recipients Tab -->
                        <page string="Recipients" name="recipients">
                            <group>
                                <field name="recipient_user_ids" widget="many2many_tags"/>
                                <field name="recipient_emails"/>
                            </group>
                        </page>
                        
                        <!-- Output Tab -->
                        <page string="Output" name="output"
                              invisible="status != 'completed'">
                            <group>
                                <field name="file_name"/>
                                <field name="file_data" filename="file_name"/>
                            </group>
                        </page>
                        
                        <!-- Error Tab -->
                        <page string="Error Details" name="error" 
                              invisible="status != 'failed'">
                            <group>
                                <field name="error_message"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Report Search View -->
    <record id="view_report_search" model="ir.ui.view">
        <field name="name">optimaai.report.search</field>
        <field name="model">optimaai.report</field>
        <field name="arch" type="xml">
            <search string="Search Reports">
                <field name="name"/>
                <filter name="draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                <filter name="completed" string="Completed" domain="[('status', '=', 'completed')]"/>
                <filter name="failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <separator/>
                <filter name="scheduled" string="Scheduled" domain="[('schedule_type', '!=', 'manual')]"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'report_type'}"/>
                    <filter string="Schedule" name="group_schedule" context="{'group_by': 'schedule_type'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Report Action -->
    <record id="action_report" model="ir.actions.act_window">
        <field name="name">Reports</field>
        <field name="res_model">optimaai.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reports found
            </p>
            <p>
                Create custom reports to visualize your data insights.
            </p>
        </field>
    </record>
    
</odoo>