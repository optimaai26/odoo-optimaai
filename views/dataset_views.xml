<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Dataset Views
         ========================================== -->
    
    <!-- Dataset Tree View -->
    <record id="view_dataset_tree" model="ir.ui.view">
        <field name="name">optimaai.dataset.tree</field>
        <field name="model">optimaai.dataset</field>
        <field name="arch" type="xml">
            <list string="Datasets" decoration-warning="status=='uploading'" decoration-success="status=='ready'">
                <field name="name"/>
                <field name="file_name"/>
                <field name="row_count"/>
                <field name="column_count"/>
                <field name="quality_score"/>
                <field name="status" widget="badge" 
                       decoration-info="status=='uploading'" 
                       decoration-warning="status=='processing'"
                       decoration-success="status=='ready'"
                       decoration-danger="status=='error'"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="create_date"/>
                <field name="uploaded_by"/>
            </list>
        </field>
    </record>
    
    <!-- Dataset Form View -->
    <record id="view_dataset_form" model="ir.ui.view">
        <field name="name">optimaai.dataset.form</field>
        <field name="model">optimaai.dataset</field>
        <field name="arch" type="xml">
            <form string="Dataset">
                <header>
                    <button name="action_process" type="object" string="Process" 
                            class="btn-primary" invisible="status not in ('uploading', 'error')"/>
                    <button name="action_archive" type="object" string="Archive"/>
                    <field name="status" widget="statusbar" 
                           statusbar_visible="uploading,processing,ready"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Dataset Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="file_name"/>
                            <field name="file_data" filename="file_name"/>
                            <field name="file_size"/>
                            <field name="row_count"/>
                            <field name="column_count"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="uploaded_by"/>
                            <field name="quality_score"/>
                            <field name="null_percentage"/>
                            <field name="duplicate_count"/>
                            <field name="processed_date"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Columns Tab -->
                        <page string="Columns" name="columns">
                            <field name="column_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="column_type"/>
                                    <field name="null_count"/>
                                    <field name="null_percentage"/>
                                    <field name="unique_count"/>
                                    <field name="is_target"/>
                                    <field name="is_feature"/>
                                </list>
                            </field>
                        </page>
                        
                        <!-- Description Tab -->
                        <page string="Description" name="description">
                            <group>
                                <field name="description" nolabel="1"/>
                            </group>
                            <group>
                                <field name="tags"/>
                            </group>
                        </page>
                        
                        <!-- Error Tab -->
                        <page string="Error Details" name="error" 
                              invisible="status != 'error'">
                            <group>
                                <field name="error_message"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Dataset Search View -->
    <record id="view_dataset_search" model="ir.ui.view">
        <field name="name">optimaai.dataset.search</field>
        <field name="model">optimaai.dataset</field>
        <field name="arch" type="xml">
            <search string="Search Datasets">
                <field name="name"/>
                <field name="file_name"/>
                <filter name="uploading" string="Uploading" domain="[('status', '=', 'uploading')]"/>
                <filter name="processing" string="Processing" domain="[('status', '=', 'processing')]"/>
                <filter name="ready" string="Ready" domain="[('status', '=', 'ready')]"/>
                <filter name="error" string="Error" domain="[('status', '=', 'error')]"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Uploaded By" name="group_uploaded" context="{'group_by': 'uploaded_by'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Dataset Kanban View -->
    <record id="view_dataset_kanban" model="ir.ui.view">
        <field name="name">optimaai.dataset.kanban</field>
        <field name="model">optimaai.dataset</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="status"/>
                <field name="row_count"/>
                <field name="file_name"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong>
                                <div class="text-muted">
                                    <i class="fa fa-file"/> <field name="file_name"/>
                                </div>
                                <div>
                                    <i class="fa fa-table"/> <field name="row_count"/> rows
                                </div>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="status" widget="label" 
                                       decoration-info="status=='uploading'"
                                       decoration-success="status=='ready'"
                                       decoration-warning="status=='processing'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Dataset Action -->
    <record id="action_dataset" model="ir.actions.act_window">
        <field name="name">Datasets</field>
        <field name="res_model">optimaai.dataset</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_dataset_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No datasets found
            </p>
            <p>
                Create your first dataset to start analyzing your data.
            </p>
        </field>
    </record>

    <!-- Dataset Column Views -->
    <record id="view_dataset_column_tree" model="ir.ui.view">
        <field name="name">optimaai.dataset.column.tree</field>
        <field name="model">optimaai.dataset.column</field>
        <field name="arch" type="xml">
            <list string="Dataset Columns">
                <field name="dataset_id"/>
                <field name="name"/>
                <field name="column_type"/>
                <field name="is_target"/>
                <field name="is_feature"/>
                <field name="unique_count"/>
                <field name="null_count"/>
                <field name="null_percentage"/>
            </list>
        </field>
    </record>
    
</odoo>