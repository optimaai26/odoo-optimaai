<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Insight Views
         ========================================== -->
    
    <!-- Insight Tree View -->
    <record id="view_insight_tree" model="ir.ui.view">
        <field name="name">optimaai.insight.tree</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <list string="Insights" 
                  decoration-danger="priority=='critical'" 
                  decoration-warning="priority=='high'"
                  multi_edit="1"
                  sample="1">
                <field name="name" string="Insight"/>
                <field name="insight_type" widget="badge"
                       decoration-info="insight_type=='trend'"
                       decoration-warning="insight_type=='anomaly'"
                       decoration-success="insight_type=='pattern'"/>
                <field name="dataset_id"/>
                <field name="priority" widget="badge" 
                       decoration-danger="priority=='critical'"
                       decoration-warning="priority=='high'"
                       decoration-info="priority=='low'"/>
                <field name="action_status" widget="badge"
                       decoration-warning="action_status=='pending'"
                       decoration-info="action_status in ('acknowledged', 'in_progress')"
                       decoration-success="action_status=='resolved'"
                       decoration-muted="action_status=='dismissed'"/>
                <field name="impact_score" widget="progressbar" optional="show"/>
                <field name="confidence_level" widget="progressbar" optional="hide"/>
                <field name="action_assigned_to" widget="many2one_avatar_user" optional="show"/>
                <field name="create_date" string="Discovered" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>
    
    <!-- Insight Form View -->
    <record id="view_insight_form" model="ir.ui.view">
        <field name="name">optimaai.insight.form</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <form string="Insight">
                <header>
                    <button name="action_acknowledge" type="object" string="Acknowledge" 
                            class="btn-primary"
                            invisible="action_status != 'pending'"/>
                    <button name="action_start" type="object" string="Start Work" 
                           
                            invisible="action_status != 'acknowledged'"/>
                    <button name="action_resolve" type="object" string="Resolve" 
                            class="btn-primary"
                            invisible="action_status != 'in_progress'"/>
                    <button name="action_dismiss" type="object" string="Dismiss" 
                           
                            invisible="action_status in ('resolved', 'dismissed')"/>
                    <field name="action_status" widget="statusbar" 
                           statusbar_visible="pending,acknowledged,in_progress,resolved"/>
                </header>
                <sheet>
                    <!-- Priority alerts -->
                    <div class="alert alert-danger mb-3" role="alert"
                         invisible="priority != 'critical'">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Critical Insight:</strong> Requires immediate attention and action.
                    </div>
                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="priority != 'high'">
                        <i class="fa fa-warning me-2"/>
                        <strong>High Priority:</strong> This insight should be reviewed promptly.
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Unusual spike in customer churn rate"/></h1>
                    </div>
                    
                    <group>
                        <group string="Classification">
                            <field name="insight_type" widget="radio"/>
                            <field name="priority" widget="radio"/>
                            <field name="is_actionable" widget="boolean_toggle"/>
                        </group>
                        <group string="Metrics">
                            <field name="impact_score" widget="progressbar"/>
                            <field name="confidence_level" widget="progressbar"/>
                            <field name="dataset_id"/>
                            <field name="prediction_id"/>
                        </group>
                    </group>

                    <group>
                        <group string="Assignment">
                            <field name="action_assigned_to" widget="many2one_avatar_user"/>
                            <field name="resolved_date"/>
                            <field name="resolved_by" widget="many2one_avatar_user"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Summary">
                            <field name="summary" nolabel="1" 
                                   placeholder="Brief summary of the insight..."/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Details Tab -->
                        <page string="Detailed Analysis" name="details">
                            <group>
                                <field name="detailed_analysis" nolabel="1"
                                       placeholder="Detailed analysis and findings..."/>
                            </group>
                            <group string="Supporting Data">
                                <field name="supporting_data" widget="text" nolabel="1" 
                                       placeholder="JSON data supporting this insight..."/>
                            </group>
                        </page>
                        
                        <!-- Action Tab -->
                        <page string="Recommended Actions" name="action">
                            <group string="Suggested Action">
                                <field name="action_suggestion" nolabel="1"
                                       placeholder="What action should be taken?"/>
                            </group>
                            <group string="Notes">
                                <field name="action_notes" nolabel="1"
                                       placeholder="Additional notes about actions taken..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Insight Search View -->
    <record id="view_insight_search" model="ir.ui.view">
        <field name="name">optimaai.insight.search</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <search string="Search Insights">
                <field name="name"/>
                <field name="dataset_id"/>
                <field name="action_assigned_to"/>
                <separator/>
                <filter name="pending" string="Pending" domain="[('action_status', '=', 'pending')]"/>
                <filter name="in_progress" string="In Progress" domain="[('action_status', '=', 'in_progress')]"/>
                <filter name="resolved" string="Resolved" domain="[('action_status', '=', 'resolved')]"/>
                <separator/>
                <filter name="critical" string="🔴 Critical" domain="[('priority', '=', 'critical')]"/>
                <filter name="high_priority" string="🟡 High" domain="[('priority', '=', 'high')]"/>
                <separator/>
                <filter name="trend" string="Trends" domain="[('insight_type', '=', 'trend')]"/>
                <filter name="anomaly" string="Anomalies" domain="[('insight_type', '=', 'anomaly')]"/>
                <filter name="pattern" string="Patterns" domain="[('insight_type', '=', 'pattern')]"/>
                <filter name="actionable" string="Actionable" domain="[('is_actionable', '=', True)]"/>
                <group>
                    <filter string="Action Status" name="group_status" context="{'group_by': 'action_status'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'insight_type'}"/>
                    <filter string="Dataset" name="group_dataset" context="{'group_by': 'dataset_id'}"/>
                    <filter string="Assigned To" name="group_assigned" context="{'group_by': 'action_assigned_to'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Insight Kanban View -->
    <record id="view_insight_kanban" model="ir.ui.view">
        <field name="name">optimaai.insight.kanban</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <kanban default_group_by="action_status" class="o_kanban_small_column" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="action_status"/>
                <field name="priority"/>
                <field name="insight_type"/>
                <field name="impact_score"/>
                <field name="dataset_id"/>
                <field name="action_assigned_to"/>
                <field name="create_date"/>
                <progressbar field="priority" 
                             colors='{"critical": "danger", "high": "warning", "medium": "info", "low": "muted"}'/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-start">
                            <field name="name" class="fw-bold"/>
                            <field name="priority" widget="label"
                                   decoration-danger="priority=='critical'"
                                   decoration-warning="priority=='high'"
                                   decoration-info="priority=='low'"/>
                        </div>
                        <div class="text-muted small mt-1">
                            <field name="insight_type" widget="badge"
                                   decoration-info="insight_type=='trend'"
                                   decoration-warning="insight_type=='anomaly'"
                                   decoration-success="insight_type=='pattern'"/>
                            <span t-if="record.dataset_id.value" class="ms-2">
                                <i class="fa fa-database me-1"/><field name="dataset_id"/>
                            </span>
                        </div>
                        <hr class="my-2"/>
                        <div class="row g-1">
                            <div class="col-6 text-center">
                                <div class="fw-bold text-primary">
                                    <t t-if="record.impact_score.value">
                                        <field name="impact_score"/>%
                                    </t>
                                    <t t-else="">—</t>
                                </div>
                                <small class="text-muted">Impact</small>
                            </div>
                            <div class="col-6 text-center">
                                <field name="action_assigned_to" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Insight Action -->
    <record id="action_insight" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_insight_search"/>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No insights yet
            </p>
            <p>
                AI-generated insights will appear here after analyzing your datasets.
            </p>
        </field>
    </record>
    
    <!-- Insight Action by Dataset -->
    <record id="action_insight_by_dataset" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('dataset_id', '=', active_id)]</field>
        <field name="context">{'default_dataset_id': active_id}</field>
    </record>
    
    <!-- Prediction Action by Insight -->
    <record id="action_prediction_by_insight" model="ir.actions.act_window">
        <field name="name">Prediction</field>
        <field name="res_model">optimaai.prediction</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
    
</odoo>