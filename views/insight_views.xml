<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Insight Views
         ========================================== -->
    
    <!-- Insight Tree View -->
    <record id="view_insight_tree" model="ir.ui.view">
        <field name="name">optimaai.insight.tree</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <tree string="Insights" decoration-danger="priority=='high'" 
                  decoration-warning="priority=='medium'" decoration-muted="status=='archived'">
                <field name="name"/>
                <field name="insight_type"/>
                <field name="dataset_id"/>
                <field name="priority" widget="badge" 
                       decoration-danger="priority=='high'"
                       decoration-warning="priority=='medium'"
                       decoration-info="priority=='low'"/>
                <field name="status" widget="badge"/>
                <field name="create_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>
    
    <!-- Insight Form View -->
    <record id="view_insight_form" model="ir.ui.view">
        <field name="name">optimaai.insight.form</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <form string="Insight">
                <header>
                    <button name="action_acknowledge" type="object" string="Acknowledge" 
                            class="btn-primary" attrs="{'invisible': [('status', '!=', 'active')]}"/>
                    <button name="action_resolve" type="object" string="Resolve" 
                            class="btn-primary" attrs="{'invisible': [('status', '!=', 'acknowledged')]}"/>
                    <button name="action_archive" type="object" string="Archive" 
                            attrs="{'invisible': [('status', '!=', 'resolved')]}"/>
                    <button name="action_reactivate" type="object" string="Reactivate" 
                            attrs="{'invisible': [('status', '!=', 'archived')]}"/>
                    <field name="status" widget="statusbar" 
                           statusbar_visible="active,acknowledged,resolved,archived"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="action" name="%(action_prediction_by_insight)d"
                                icon="fa-magic" string="Prediction"
                                attrs="{'invisible': [('prediction_id', '=', False)]}">
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Insight Title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="insight_type"/>
                            <field name="priority"/>
                            <field name="dataset_id"/>
                            <field name="prediction_id"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="acknowledged_date"/>
                            <field name="resolved_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <group string="Description">
                        <field name="description" nolabel="1" widget="html"/>
                    </group>
                    
                    <notebook>
                        <!-- Details Tab -->
                        <page string="Details" name="details">
                            <group>
                                <field name="insight_data" widget="text"/>
                            </group>
                        </page>
                        
                        <!-- Recommendations Tab -->
                        <page string="Recommendations" name="recommendations">
                            <group>
                                <field name="recommendations" nolabel="1" widget="html"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Insight Search View -->
    <record id="view_insight_search" model="ir.ui.view">
        <field name="name">optimaai.insight.search</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <search string="Search Insights">
                <field name="name"/>
                <field name="dataset_id"/>
                <filter name="active" string="Active" domain="[('status', '=', 'active')]"/>
                <filter name="acknowledged" string="Acknowledged" domain="[('status', '=', 'acknowledged')]"/>
                <filter name="resolved" string="Resolved" domain="[('status', '=', 'resolved')]"/>
                <separator/>
                <filter name="high_priority" string="High Priority" domain="[('priority', '=', 'high')]"/>
                <filter name="trend" string="Trends" domain="[('insight_type', '=', 'trend')]"/>
                <filter name="anomaly" string="Anomalies" domain="[('insight_type', '=', 'anomaly')]"/>
                <filter name="pattern" string="Patterns" domain="[('insight_type', '=', 'pattern')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'insight_type'}"/>
                    <filter string="Dataset" name="group_dataset" context="{'group_by': 'dataset_id'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Insight Kanban View -->
    <record id="view_insight_kanban" model="ir.ui.view">
        <field name="name">optimaai.insight.kanban</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="status"/>
                <field name="priority"/>
                <field name="insight_type"/>
                <field name="dataset_id"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div class="text-muted">
                                    <i class="fa fa-lightbulb-o"/> <field name="insight_type"/>
                                    <span t-if="record.dataset_id.value">
                                        - <field name="dataset_id"/>
                                    </span>
                                </div>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="status" widget="label"
                                       decoration-info="status=='active'"
                                       decoration-warning="status=='acknowledged'"
                                       decoration-success="status=='resolved'"
                                       decoration-muted="status=='archived'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Insight Action -->
    <record id="action_insight" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="view_insight_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No insights found
            </p>
            <p>
                AI-generated insights will appear here after analyzing your datasets.
            </p>
        </field>
    </record>
    
    <!-- Insight Action by Dataset -->
    <record id="action_insight_by_dataset" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('dataset_id', '=', active_id)]</field>
        <field name="context">{'default_dataset_id': active_id}</field>
    </record>
    
    <!-- Insight Action by Prediction -->
    <record id="action_prediction_by_insight" model="ir.actions.act_window">
        <field name="name">Prediction</field>
        <field name="res_model">optimaai.prediction</field>
        <field name="view_mode">form</field>
        <field name="domain">[('id', '=', prediction_id)]</field>
        <field name="target">current</field>
    </record>
    
</odoo>