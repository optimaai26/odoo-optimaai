<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Insight Views
         ========================================== -->
    
    <!-- Insight Tree View -->
    <record id="view_insight_tree" model="ir.ui.view">
        <field name="name">optimaai.insight.tree</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <list string="Insights" decoration-danger="priority=='critical'" 
                  decoration-warning="priority=='high'">
                <field name="name"/>
                <field name="insight_type"/>
                <field name="dataset_id"/>
                <field name="priority" widget="badge" 
                       decoration-danger="priority=='critical'"
                       decoration-warning="priority=='high'"
                       decoration-info="priority=='low'"/>
                <field name="action_status" widget="badge"/>
                <field name="impact_score"/>
                <field name="create_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    
    <!-- Insight Form View -->
    <record id="view_insight_form" model="ir.ui.view">
        <field name="name">optimaai.insight.form</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <form string="Insight">
                <header>
                    <button name="action_acknowledge" type="object" string="Acknowledge" 
                            class="btn-primary" invisible="action_status != 'pending'"/>
                    <button name="action_start" type="object" string="Start Work" 
                            invisible="action_status != 'acknowledged'"/>
                    <button name="action_resolve" type="object" string="Resolve" 
                            class="btn-primary" invisible="action_status != 'in_progress'"/>
                    <button name="action_dismiss" type="object" string="Dismiss" 
                            invisible="action_status in ('resolved', 'dismissed')"/>
                    <field name="action_status" widget="statusbar" 
                           statusbar_visible="pending,acknowledged,in_progress,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Insight Title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="insight_type"/>
                            <field name="priority"/>
                            <field name="impact_score"/>
                            <field name="confidence_level"/>
                            <field name="dataset_id"/>
                            <field name="prediction_id"/>
                        </group>
                        <group>
                            <field name="action_status"/>
                            <field name="is_actionable"/>
                            <field name="action_assigned_to"/>
                            <field name="resolved_date"/>
                            <field name="resolved_by"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <group string="Summary">
                        <field name="summary" nolabel="1"/>
                    </group>
                    
                    <notebook>
                        <!-- Details Tab -->
                        <page string="Details" name="details">
                            <group>
                                <field name="detailed_analysis"/>
                            </group>
                            <group>
                                <field name="supporting_data" widget="text"/>
                            </group>
                        </page>
                        
                        <!-- Action Tab -->
                        <page string="Action" name="action">
                            <group>
                                <field name="action_suggestion"/>
                                <field name="action_notes"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Insight Search View -->
    <record id="view_insight_search" model="ir.ui.view">
        <field name="name">optimaai.insight.search</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <search string="Search Insights">
                <field name="name"/>
                <field name="dataset_id"/>
                <filter name="pending" string="Pending" domain="[('action_status', '=', 'pending')]"/>
                <filter name="in_progress" string="In Progress" domain="[('action_status', '=', 'in_progress')]"/>
                <filter name="resolved" string="Resolved" domain="[('action_status', '=', 'resolved')]"/>
                <separator/>
                <filter name="critical" string="Critical" domain="[('priority', '=', 'critical')]"/>
                <filter name="high_priority" string="High Priority" domain="[('priority', '=', 'high')]"/>
                <filter name="trend" string="Trends" domain="[('insight_type', '=', 'trend')]"/>
                <filter name="anomaly" string="Anomalies" domain="[('insight_type', '=', 'anomaly')]"/>
                <filter name="pattern" string="Patterns" domain="[('insight_type', '=', 'pattern')]"/>
                <group>
                    <filter string="Action Status" name="group_status" context="{'group_by': 'action_status'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'insight_type'}"/>
                    <filter string="Dataset" name="group_dataset" context="{'group_by': 'dataset_id'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Insight Kanban View -->
    <record id="view_insight_kanban" model="ir.ui.view">
        <field name="name">optimaai.insight.kanban</field>
        <field name="model">optimaai.insight</field>
        <field name="arch" type="xml">
            <kanban default_group_by="action_status" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="action_status"/>
                <field name="priority"/>
                <field name="insight_type"/>
                <field name="dataset_id"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                                <div class="text-muted">
                                    <i class="fa fa-lightbulb-o"/> <field name="insight_type"/>
                                    <span t-if="record.dataset_id.value">
                                        - <field name="dataset_id"/>
                                    </span>
                                </div>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="priority" widget="label"
                                       decoration-danger="priority=='critical'"
                                       decoration-warning="priority=='high'"
                                       decoration-info="priority=='low'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Insight Action -->
    <record id="action_insight" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_insight_search"/>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No insights found
            </p>
            <p>
                AI-generated insights will appear here after analyzing your datasets.
            </p>
        </field>
    </record>
    
    <!-- Insight Action by Dataset -->
    <record id="action_insight_by_dataset" model="ir.actions.act_window">
        <field name="name">Insights</field>
        <field name="res_model">optimaai.insight</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('dataset_id', '=', active_id)]</field>
        <field name="context">{'default_dataset_id': active_id}</field>
    </record>
    
    <!-- Prediction Action by Insight -->
    <record id="action_prediction_by_insight" model="ir.actions.act_window">
        <field name="name">Prediction</field>
        <field name="res_model">optimaai.prediction</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
    
</odoo>