<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Canvas Views
         ========================================== -->
    
    <!-- Canvas Tree View -->
    <record id="view_canvas_tree" model="ir.ui.view">
        <field name="name">optimaai.canvas.tree</field>
        <field name="model">optimaai.canvas</field>
        <field name="arch" type="xml">
            <list string="Canvases">
                <field name="name"/>
                <field name="canvas_type"/>
                <field name="status" widget="badge"/>
                <field name="created_by"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>
    
    <!-- Canvas Form View -->
    <record id="view_canvas_form" model="ir.ui.view">
        <field name="name">optimaai.canvas.form</field>
        <field name="model">optimaai.canvas</field>
        <field name="arch" type="xml">
            <form string="Canvas">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Canvas Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="canvas_type"/>
                            <field name="status"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="created_by"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Configuration Tab -->
                        <page string="Configuration" name="configuration">
                            <group>
                                <field name="config" nolabel="1" widget="text"/>
                            </group>
                        </page>
                        
                        <!-- Blocks Tab -->
                        <page string="Blocks" name="blocks">
                            <field name="block_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="block_type"/>
                                    <field name="sequence"/>
                                    <field name="position_x"/>
                                    <field name="position_y"/>
                                </list>
                            </field>
                        </page>
                        
                        <!-- Connections Tab -->
                        <page string="Connections" name="connections">
                            <field name="connection_ids">
                                <list editable="bottom">
                                    <field name="source_block_id"/>
                                    <field name="target_block_id"/>
                                    <field name="connection_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Canvas Search View -->
    <record id="view_canvas_search" model="ir.ui.view">
        <field name="name">optimaai.canvas.search</field>
        <field name="model">optimaai.canvas</field>
        <field name="arch" type="xml">
            <search string="Search Canvases">
                <field name="name"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'canvas_type'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Canvas Action -->
    <record id="action_canvas" model="ir.actions.act_window">
        <field name="name">Canvases</field>
        <field name="res_model">optimaai.canvas</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_canvas_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No canvases found
            </p>
            <p>
                Create a canvas to design data workflows and analysis pipelines.
            </p>
        </field>
    </record>
    
    <!-- Canvas Block Views -->
    <record id="view_canvas_block_tree" model="ir.ui.view">
        <field name="name">optimaai.canvas.block.tree</field>
        <field name="model">optimaai.canvas.block</field>
        <field name="arch" type="xml">
            <list string="Canvas Blocks">
                <field name="canvas_id"/>
                <field name="name"/>
                <field name="block_type"/>
                <field name="sequence"/>
            </list>
        </field>
    </record>
    
    <record id="view_canvas_block_form" model="ir.ui.view">
        <field name="name">optimaai.canvas.block.form</field>
        <field name="model">optimaai.canvas.block</field>
        <field name="arch" type="xml">
            <form string="Canvas Block">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Block Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="canvas_id"/>
                            <field name="block_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="position_x"/>
                            <field name="position_y"/>
                        </group>
                    </group>
                    <group string="Configuration">
                        <field name="config" nolabel="1" widget="text"/>
                    </group>
                    <group string="Output">
                        <field name="result_data" nolabel="1" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_canvas_block" model="ir.actions.act_window">
        <field name="name">Canvas Blocks</field>
        <field name="res_model">optimaai.canvas.block</field>
        <field name="view_mode">list,form</field>
    </record>
    
</odoo>