<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================================
         Canvas Views
         ========================================== -->
    
    <!-- Canvas Tree View -->
    <record id="view_canvas_tree" model="ir.ui.view">
        <field name="name">optimaai.canvas.tree</field>
        <field name="model">optimaai.canvas</field>
        <field name="arch" type="xml">
            <list string="Canvases" multi_edit="1" sample="1">
                <field name="name" string="Canvas"/>
                <field name="canvas_type" widget="badge"
                       decoration-info="canvas_type=='analysis'"
                       decoration-success="canvas_type=='pipeline'"
                       decoration-warning="canvas_type=='workflow'"/>
                <field name="status" widget="badge"
                       decoration-muted="status=='draft'"
                       decoration-info="status=='active'"
                       decoration-success="status=='completed'"
                       decoration-danger="status=='archived'"/>
                <field name="created_by" widget="many2one_avatar_user"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="create_date" string="Created" optional="hide"/>
            </list>
        </field>
    </record>
    
    <!-- Canvas Form View -->
    <record id="view_canvas_form" model="ir.ui.view">
        <field name="name">optimaai.canvas.form</field>
        <field name="model">optimaai.canvas</field>
        <field name="arch" type="xml">
            <form string="Canvas">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Customer Segmentation Pipeline"/></h1>
                    </div>
                    
                    <group>
                        <group string="Settings">
                            <field name="canvas_type" widget="radio"/>
                            <field name="status"/>
                        </group>
                        <group string="Info">
                            <field name="description" placeholder="Describe what this canvas does..."/>
                            <field name="created_by" widget="many2one_avatar_user"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Configuration Tab -->
                        <page string="Configuration" name="configuration">
                            <group>
                                <field name="config" nolabel="1" widget="text"
                                       placeholder="JSON configuration for this canvas..."/>
                            </group>
                        </page>
                        
                        <!-- Blocks Tab -->
                        <page string="Blocks" name="blocks">
                            <field name="block_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="block_type" widget="badge"/>
                                    <field name="position_x"/>
                                    <field name="position_y"/>
                                </list>
                            </field>
                        </page>
                        
                        <!-- Connections Tab -->
                        <page string="Connections" name="connections">
                            <field name="connection_ids">
                                <list editable="bottom">
                                    <field name="source_block_id"/>
                                    <field name="target_block_id"/>
                                    <field name="connection_type" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Canvas Search View -->
    <record id="view_canvas_search" model="ir.ui.view">
        <field name="name">optimaai.canvas.search</field>
        <field name="model">optimaai.canvas</field>
        <field name="arch" type="xml">
            <search string="Search Canvases">
                <field name="name"/>
                <field name="created_by"/>
                <separator/>
                <filter name="active" string="Active" domain="[('status', '=', 'active')]"/>
                <filter name="draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'canvas_type'}"/>
                    <filter string="Creator" name="group_creator" context="{'group_by': 'created_by'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Canvas Kanban View (NEW) -->
    <record id="view_canvas_kanban" model="ir.ui.view">
        <field name="name">optimaai.canvas.kanban</field>
        <field name="model">optimaai.canvas</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="canvas_type"/>
                <field name="status"/>
                <field name="created_by"/>
                <field name="description"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-start">
                            <field name="name" class="fw-bold fs-5"/>
                            <field name="canvas_type" widget="badge"
                                   decoration-info="canvas_type=='analysis'"
                                   decoration-success="canvas_type=='pipeline'"
                                   decoration-warning="canvas_type=='workflow'"/>
                        </div>
                        <div class="text-muted small mt-1" t-if="record.description.value">
                            <field name="description"/>
                        </div>
                        <hr class="my-2"/>
                        <div class="d-flex justify-content-between align-items-center">
                            <field name="created_by" widget="many2one_avatar_user"/>
                            <field name="status" widget="label"
                                   decoration-muted="status=='draft'"
                                   decoration-info="status=='active'"
                                   decoration-success="status=='completed'"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Canvas Action -->
    <record id="action_canvas" model="ir.actions.act_window">
        <field name="name">Canvases</field>
        <field name="res_model">optimaai.canvas</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_canvas_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Design your first canvas
            </p>
            <p>
                Create a canvas to design data workflows and analysis pipelines visually.
            </p>
        </field>
    </record>
    
    <!-- Canvas Block Views -->
    <record id="view_canvas_block_tree" model="ir.ui.view">
        <field name="name">optimaai.canvas.block.tree</field>
        <field name="model">optimaai.canvas.block</field>
        <field name="arch" type="xml">
            <list string="Canvas Blocks">
                <field name="sequence" widget="handle"/>
                <field name="canvas_id"/>
                <field name="name"/>
                <field name="block_type" widget="badge"/>
            </list>
        </field>
    </record>
    
    <record id="view_canvas_block_form" model="ir.ui.view">
        <field name="name">optimaai.canvas.block.form</field>
        <field name="model">optimaai.canvas.block</field>
        <field name="arch" type="xml">
            <form string="Canvas Block">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Block Name"/></h1>
                    </div>
                    <group>
                        <group string="Block Settings">
                            <field name="canvas_id"/>
                            <field name="block_type" widget="radio"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Position">
                            <field name="position_x"/>
                            <field name="position_y"/>
                        </group>
                    </group>
                    <group string="Configuration">
                        <field name="config" nolabel="1" widget="text"
                               placeholder="JSON configuration for this block..."/>
                    </group>
                    <group string="Output">
                        <field name="result_data" nolabel="1" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_canvas_block" model="ir.actions.act_window">
        <field name="name">Canvas Blocks</field>
        <field name="res_model">optimaai.canvas.block</field>
        <field name="view_mode">list,form</field>
    </record>
    
</odoo>