<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

    <!-- ==========================================
         Notification Bell Systray Template
         ========================================== -->

    <t t-name="optimaai.NotificationBell">
        <div class="o_optimaai_systray">
            <div class="o_notification_bell position-relative" t-on-click="togglePanel"
                 role="button" aria-label="Notifications">
                <i class="fa fa-bell fa-lg"/>
                <span t-if="state.count > 0"
                      class="o_notification_count badge rounded-pill bg-danger position-absolute top-0 start-100 translate-middle"
                      t-esc="formattedCount"/>
            </div>

            <!-- Notification Panel Slide-out -->
            <div t-attf-class="o_notification_panel #{state.panelOpen ? 'o_open' : ''}">
                <div class="o_notification_header">
                    <h5 class="mb-0 fw-bold">Notifications</h5>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-link text-muted" t-on-click="markAllRead">
                            Mark all read
                        </button>
                        <button class="btn btn-sm btn-link text-muted" t-on-click="closePanel">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                </div>
                <div class="o_notification_list">
                    <t t-if="state.notifications.length === 0">
                        <div class="o_empty_state p-4 text-center text-muted">
                            <i class="fa fa-bell-slash fa-2x mb-2"/>
                            <p>No notifications</p>
                        </div>
                    </t>
                    <t t-foreach="state.notifications" t-as="notif" t-key="notif.id">
                        <div t-attf-class="o_notification_item o_notification_#{notif.notification_type} #{notif.is_read ? '' : 'o_unread'}"
                             t-on-click="() => this.onNotificationClick(notif)">
                            <div class="o_notification_title">
                                <i t-attf-class="fa #{getTypeIcon(notif.notification_type)} me-2"/>
                                <t t-esc="notif.name"/>
                            </div>
                            <div class="o_notification_message" t-esc="notif.message"/>
                            <div class="o_notification_time" t-esc="notif.create_date"/>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>




    <!-- ==========================================
         Dataset Preview Template
         ========================================== -->

    <t t-name="optimaai.DatasetPreview">
        <div class="o_dataset_preview">
            <table class="o_data_table table table-sm">
                <thead>
                    <tr>
                        <t t-foreach="state.columns" t-as="col" t-key="col">
                            <th t-esc="col"/>
                        </t>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="state.data" t-as="row" t-key="row_index">
                        <tr class="o_dataset_row"
                            t-on-click="() => this.onRowClick(row, row_index)">
                            <t t-foreach="state.columns" t-as="col" t-key="col">
                                <td t-esc="row[col] !== undefined ? row[col] : ''"/>
                            </t>
                        </tr>
                    </t>
                </tbody>
            </table>
            <t t-if="state.data.length === 0">
                <div class="o_empty_state">
                    <i class="fa fa-table o_empty_state_icon"/>
                    <p class="o_empty_state_title">No data to display</p>
                </div>
            </t>
        </div>
    </t>


    <!-- ==========================================
         Prediction Result Template
         ========================================== -->

    <t t-name="optimaai.PredictionResult">
        <div class="o_prediction_result">
            <div t-attf-class="o_prediction_confidence #{confidenceClass}"
                 t-esc="confidencePercent + '%'"/>
            <div class="o_prediction_confidence_label">Confidence Score</div>
        </div>
    </t>




    <!-- ==========================================
         Canvas Dashboard Template
         ========================================== -->

    <t t-name="optimaai.CanvasDashboard">
        <div class="o_canvas_container" t-att-style="gridStyle">
            <t t-foreach="state.blocks" t-as="block" t-key="block.id">
                <div class="o_canvas_block" t-att-style="getBlockStyle(block)">
                    <div class="o_canvas_block_header">
                        <span class="o_canvas_block_title">
                            <i t-attf-class="fa #{getBlockTypeIcon(block.block_type)} me-2"/>
                            <t t-esc="block.name"/>
                        </span>
                        <button class="btn btn-sm text-muted"
                                t-on-click="() => this.removeBlock(block.id)">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                    <div class="o_canvas_block_content">
                        <p class="text-muted text-center p-4">
                            <i t-attf-class="fa #{getBlockTypeIcon(block.block_type)} fa-2x mb-2 d-block"/>
                            <t t-esc="block.block_type"/> block
                        </p>
                    </div>
                </div>
            </t>
            <t t-if="state.blocks.length === 0">
                <div class="o_empty_state">
                    <i class="fa fa-th-large o_empty_state_icon"/>
                    <p class="o_empty_state_title">No blocks yet</p>
                    <p class="o_empty_state_description">Add blocks to build your canvas</p>
                </div>
            </t>
        </div>
    </t>


    <!-- ==========================================
         Main Dashboard Template
         ========================================== -->

    <t t-name="optimaai.Dashboard">
        <div class="o_optimaai_dashboard">
            <!-- Dark Gradient Header -->
            <div class="o_dashboard_header">
                <div>
                    <h1>
                        <i class="fa fa-tachometer me-2"/>
                        OptimaAI Dashboard
                    </h1>
                    <div class="o_header_subtitle">Real-time AI analytics &amp; performance metrics</div>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="o_loading_overlay">
                    <div class="o_spinner"/>
                </div>
            </t>

            <t t-else="">
                <!-- KPI Metric Strip -->
                <div class="o_metric_strip">
                    <div class="o_metric_card o_green"
                         t-on-click="() => this.navigateTo('optimaai.action_dataset')">
                        <div class="o_metric_value" t-esc="state.datasets.total"/>
                        <div class="o_metric_label">Total Datasets</div>
                    </div>
                    <div class="o_metric_card o_blue"
                         t-on-click="() => this.navigateTo('optimaai.action_prediction')">
                        <div class="o_metric_value" t-esc="completedPredictions"/>
                        <div class="o_metric_label">Predictions Done</div>
                    </div>
                    <div class="o_metric_card o_teal">
                        <div class="o_metric_value"><t t-esc="avgConfidence"/>%</div>
                        <div class="o_metric_label">Avg Confidence</div>
                    </div>
                    <div class="o_metric_card o_orange"
                         t-on-click="() => this.navigateTo('optimaai.action_insight')">
                        <div class="o_metric_value" t-esc="state.insights.total"/>
                        <div class="o_metric_label">Active Insights</div>
                    </div>
                    <div class="o_metric_card o_red">
                        <div class="o_metric_value" t-esc="criticalInsights"/>
                        <div class="o_metric_label">Critical Alerts</div>
                    </div>
                    <div class="o_metric_card o_purple"
                         t-on-click="() => this.navigateTo('optimaai.action_kpi')">
                        <div class="o_metric_value">
                            <t t-esc="onTrackKpis"/>/<t t-esc="state.kpis.total"/>
                        </div>
                        <div class="o_metric_label">KPIs On Track</div>
                    </div>
                    <div class="o_metric_card o_navy">
                        <div class="o_metric_value"><t t-esc="avgQuality"/>%</div>
                        <div class="o_metric_label">Data Quality Avg</div>
                    </div>
                </div>

                <!-- Main Content Body -->
                <div class="o_dashboard_body">

                    <!-- Charts Row -->
                    <div class="o_charts_row">
                        <div class="o_chart_panel">
                            <div class="o_chart_title">Predictions by Type</div>
                            <canvas t-ref="chartPredictions"/>
                        </div>
                        <div class="o_chart_panel">
                            <div class="o_chart_title">Insights by Priority</div>
                            <canvas t-ref="chartInsights"/>
                        </div>
                        <div class="o_chart_panel">
                            <div class="o_chart_title">Datasets by Status</div>
                            <canvas t-ref="chartDatasets"/>
                        </div>
                    </div>

                    <!-- KPI Performance Table -->
                    <div class="o_kpi_table_section" t-if="state.recentKpis.length">
                        <div class="o_table_title">
                            <i class="fa fa-table me-2"/>KPI Performance Overview
                        </div>
                        <table class="o_kpi_perf_table">
                            <thead>
                                <tr>
                                    <th>KPI Name</th>
                                    <th>Current</th>
                                    <th>Target</th>
                                    <th>Progress</th>
                                    <th>Status</th>
                                    <th>Trend</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.recentKpis" t-as="kpi" t-key="kpi.id">
                                    <tr>
                                        <td class="o_kpi_name_col">
                                            <span t-attf-class="o_kpi_icon o_kpi_icon_#{kpi.category || 'operational'}">
                                                <i class="fa fa-chart-line"/>
                                            </span>
                                            <t t-esc="kpi.name"/>
                                        </td>
                                        <td class="o_kpi_value_col">
                                            <t t-esc="formatKpiValue(kpi.value, kpi.unit)"/>
                                        </td>
                                        <td class="o_kpi_target_col">
                                            <t t-esc="formatKpiValue(kpi.target_value, kpi.unit)"/>
                                        </td>
                                        <td class="o_progress_cell">
                                            <div class="o_mini_progress">
                                                <div class="o_mini_bar"
                                                     t-attf-style="width: #{Math.min(100, kpi.progress_percentage || 0)}%; background: #{getProgressColor(kpi.progress_percentage || 0)}"/>
                                            </div>
                                            <div class="o_progress_label">
                                                <t t-esc="Math.round(kpi.progress_percentage || 0)"/>%
                                            </div>
                                        </td>
                                        <td>
                                            <span t-attf-class="o_status_pill o_#{kpi.status || 'critical'}">
                                                <t t-esc="(kpi.status || 'N/A').replace('_', ' ')"/>
                                            </span>
                                        </td>
                                        <td>
                                            <span t-attf-class="o_trend_indicator o_#{kpi.trend || 'stable'}">
                                                <i t-attf-class="fa #{getTrendIcon(kpi.trend)}"/>
                                                <t t-esc="(kpi.trend || 'stable')"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>

                    <!-- Active Insights Grid -->
                    <div class="o_insights_section" t-if="state.activeInsights.length">
                        <div class="o_section_title">
                            <i class="fa fa-lightbulb-o me-2"/>Active Insights
                        </div>
                        <div class="o_insights_grid">
                            <t t-foreach="state.activeInsights" t-as="insight" t-key="insight.id">
                                <div t-attf-class="o_insight_panel o_priority_#{insight.priority}">
                                    <div class="o_insight_header">
                                        <div class="o_insight_title" t-esc="insight.name"/>
                                        <span class="o_insight_type_badge" t-esc="insight.insight_type"/>
                                    </div>
                                    <div class="o_insight_summary" t-esc="insight.description"/>
                                    <div class="o_insight_actions">
                                        <button class="btn btn-sm btn-outline-primary"
                                                t-on-click="() => this.onInsightActivate(insight.id)">
                                            <i class="fa fa-check me-1"/>View
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                t-on-click="() => this.onInsightDismiss(insight.id)">
                                            <i class="fa fa-times me-1"/>Dismiss
                                        </button>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="o_quick_actions">
                        <div class="o_section_title">
                            <i class="fa fa-rocket me-2"/>Quick Actions
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="o_action_btn"
                                    t-on-click="() => this.navigateTo('optimaai.action_dataset')">
                                <i class="fa fa-database"/>View Datasets
                            </button>
                            <button class="o_action_btn"
                                    t-on-click="() => this.navigateTo('optimaai.action_prediction')">
                                <i class="fa fa-magic"/>View Predictions
                            </button>
                            <button class="o_action_btn"
                                    t-on-click="() => this.navigateTo('optimaai.action_insight')">
                                <i class="fa fa-lightbulb-o"/>View Insights
                            </button>
                            <button class="o_action_btn"
                                    t-on-click="() => this.navigateTo('optimaai.action_canvas')">
                                <i class="fa fa-th-large"/>Open Canvas
                            </button>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>

</templates>
